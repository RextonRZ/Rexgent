# Qwen Cloud
QWEN_API_KEY=your_qwen_api_key
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Alibaba Cloud OSS
OSS_ACCESS_KEY_ID=your_key_id
OSS_ACCESS_KEY_SECRET=your_secret
OSS_BUCKET_NAME=rexgent-assets
OSS_ENDPOINT=https://oss-ap-southeast-1.aliyuncs.com

# Database
DATABASE_URL=postgresql://rexgent:rexgent_dev@localhost:5432/rexgent
REDIS_URL=redis://localhost:6379/0

# App
SECRET_KEY=change-me-in-production
ENVIRONMENT=development

# Neo4j (narrative graph)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=rexgent_dev

# Qwen-Max token cost (USD per 1k tokens)
QWEN_MAX_INPUT_COST_PER_1K=0.0016
QWEN_MAX_OUTPUT_COST_PER_1K=0.0064
